# Maintainer: OfficalConus <officalconus@users.noreply.github.com>
pkgname=gtui
pkgver=1.0
pkgrel=1
pkgdesc="Gmail TUI client with Catppuccin Mocha themes"
arch=('any')
url="https://github.com/OfficalConus/gtui"
license=('MIT')
depends=('python' 'python-textual' 'python-google-api-python-client'
         'python-google-auth-oauthlib' 'python-google-auth-httplib2' 'httplib2')
source=("$pkgname-$pkgver.tar.zst::https://github.com/OfficalConus/gtui/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

package() {
  install -Dm755 "$srcdir"/gtui.py "$pkgdir"/usr/bin/gtui
  install -Dm644 "$srcdir"/README.md "$pkgdir"/usr/share/doc/gtui/README.md
  install -Dm644 "$srcdir"/docs/index.html "$pkgdir"/usr/share/doc/gtui/site/index.html
}
